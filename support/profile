# Change SELinux label to unshare the volume with the containers?
if test -e /sys/fs/selinux/enforce && grep -q 1 /sys/fs/selinux/enforce
then
	DOSH_MOUNT_OPTIONS="Z"
	export DOSH_MOUNT_OPTIONS
fi

# Not /bin/sh?
if [ "$SHELL" != "/bin/sh" ]
then
	export DOSHELL="$SHELL"
fi

# Map and export ssh things?
if [ -d "$HOME/.ssh" ]
then
	DOSH_DOCKER_RUN_EXTRA_OPTS+=" --volume $HOME/.ssh:$HOME/.ssh:${DOSH_MOUNT_OPTIONS:-rw}"
fi
if [ -n "$SSH_AUTH_SOCK" ]
then
	DOSH_DOCKER_RUN_EXTRA_OPTS+=" --env SSH_AUTH_SOCK"
	DOSH_DOCKER_RUN_EXTRA_OPTS+=" --volume $SSH_AUTH_SOCK:$SSH_AUTH_SOCK:${DOSH_MOUNT_OPTIONS:-rw}"
fi
export DOSH_DOCKER_RUN_EXTRA_OPTS
